# Donor Map Research Pipeline — API Keys
# Copy this file to .env and add your keys.
# .env is gitignored — never commit real API keys.

# ── Core APIs (Politicians & Donors) ──────────────────

# FEC API (https://api.open.fec.gov/developers/)
# Free registration: 1,000 requests/hour (vs 40/hr with DEMO_KEY)
FEC_API_KEY=DEMO_KEY

# Congress.gov API (https://api.congress.gov/sign-up/)
# Free registration: 5,000 requests/hour
CONGRESS_API_KEY=DEMO_KEY

# Senate LDA API (Lobbying Disclosure)
# Default key is public — replace with your own if needed
LDA_API_KEY=b3e00f77b9db54cd753ca43bb8773f9e8b0ec5c4

# OpenSecrets API (https://www.opensecrets.org/api/admin/index.php?function=signup)
# Free registration: 200 requests/day
# Top contributors, industry totals, candidate summaries
OPENSECRETS_API_KEY=

# ── Think Tanks & Nonprofits ──────────────────────────

# ProPublica Nonprofit Explorer — NO KEY NEEDED
# 990 tax filings: revenue, exec pay, grants, donors
# https://projects.propublica.org/nonprofits/api

# ── Foreign Lobbying ──────────────────────────────────

# FARA (DOJ Foreign Agents Registration) — NO KEY NEEDED
# Who lobbies for which foreign government
# https://efile.fara.gov/

# ── State-Level Campaign Finance ──────────────────────

# FollowTheMoney (https://www.followthemoney.org/our-data/api)
# Free registration — state-level campaign finance, all 50 states
# Essential for: CA Governor 2026, state races
FOLLOWTHEMONEY_API_KEY=

# ── Bill Tracking ─────────────────────────────────────

# GovTrack — NO KEY NEEDED
# Enhanced bill tracking, vote analysis, legislator stats
# https://www.govtrack.us/developers/api

# ── Bulk Data Downloads (manual) ──────────────────────
# These aren't APIs but downloadable datasets:
#
# FEC Bulk Data: https://www.fec.gov/data/browse-data/?tab=bulk-data
#   - All contributions, all committees, all candidates (CSV)
#
# IRS Exempt Organizations: https://www.irs.gov/charities-non-profits/tax-exempt-organization-search-bulk-data-downloads
#   - All 501(c)(3), 501(c)(4) orgs with financial data
#   - Essential for dark money groups, think tank funding
#
# ProPublica 990 Bulk: https://projects.propublica.org/nonprofits/api#bulk-data
#   - Complete 990 filings in XML/JSON
#
# FPPC (California): https://www.fppc.ca.gov/transparency/campaign-finance.html
#   - California state campaign finance
#   - Essential for CA Governor 2026 race
