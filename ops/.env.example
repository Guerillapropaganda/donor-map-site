# ─────────────────────────────────────────────────────────────────
#  Phase 2.5 environment template — THE DONOR MAP Ops
#
#  1. Copy this file to .env.local (which is gitignored)
#  2. Replace every _PASTE_HERE placeholder with real values
#  3. Restart `npm run dev` after editing so Next.js reloads env vars
#
#  Full walkthrough: content/Admin Notes/phase-2.5-setup.md
# ─────────────────────────────────────────────────────────────────

# ─── Clerk (from clerk.com dashboard → API Keys) ────────────────────
# Publishable key is safe to expose (NEXT_PUBLIC_* gets bundled to client)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_PASTE_HERE

# Secret key NEVER goes in NEXT_PUBLIC_* and NEVER commits to git
CLERK_SECRET_KEY=sk_test_PASTE_HERE

# Route configuration — these are the URLs of the catch-all pages
# already scaffolded in ops/src/app/sign-in and ops/src/app/sign-up.
# Don't change unless you also move those files.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account

# ─── Stripe (from dashboard.stripe.com → Developers → API keys) ─────
STRIPE_SECRET_KEY=sk_test_PASTE_HERE

# ─── Stripe webhook signing secret ──────────────────────────────────
# For LOCAL testing: run `stripe listen --forward-to localhost:3333/api/stripe/webhook`
# and paste the webhook secret that the Stripe CLI prints (starts with whsec_).
#
# For PRODUCTION: create a webhook endpoint in Stripe Dashboard
# (Developers → Webhooks → Add endpoint), select the 4 events listed
# in the setup doc, and paste the endpoint's signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_PASTE_HERE

# ─── Stripe price IDs (from the Products you create in Stripe Dashboard) ─
# Create 4 products with these exact price structures:
#   Researcher          $20.00  recurring monthly
#   Researcher Student  $10.00  recurring monthly   (50% off, honor system)
#   Newsroom            $150.00 recurring monthly
#   Patron              $500.00 one-time
# After creating each product, click it and copy its Price ID (price_1...)
STRIPE_PRICE_RESEARCHER=price_1_PASTE_HERE
STRIPE_PRICE_RESEARCHER_STUDENT=price_1_PASTE_HERE
STRIPE_PRICE_NEWSROOM=price_1_PASTE_HERE
STRIPE_PRICE_PATRON=price_1_PASTE_HERE
