.DS_Store
.gitignore
node_modules
public
prof
tsconfig.tsbuildinfo
.obsidian
.quartz-cache
private/
.replit
replit.nix
link-report.md
reports/
content/Vault Maintenance/Pipeline Reports/
.claude/worktrees/
.env
# Bulk CSV downloads (too large for git — processed output goes to data/*.jsonl)
# Pattern: ignore EVERYTHING inside data/bulk/, but re-include the
# directories themselves, README.md files, and any explicitly-tracked
# research subdirs (small curated CSVs we want preserved in version
# history — distinct from raw multi-hundred-MB bulk dumps).
# Once a parent is fully excluded, `!` can't reach back in — so we
# explicitly re-include subdirs first, then the specific files.
data/bulk/**
!data/bulk/
!data/bulk/**/
!data/bulk/**/README.md
# Research subdirs — small curated source files (CSVs, markdown reports)
# that we want preserved across machines + in version history. Each
# subdir is named with the source + date (e.g. perplexity-2026-04-29).
!data/bulk/**/perplexity-*/**
!data/bulk/**/research-*/**

ops/.next/
ops/.env.local
ops/data/

# Security scan reports (never commit scan output)
.security/

# Profile template generator backups (per-profile .before files)
**/.template-backup/

# Attention dispatcher rotating log
content/Admin Notes/.attention-dispatcher.log
content/Admin Notes/.attention-dispatcher.log.1
data/derived/fec-oth-transfers.jsonl
# govinfo-bill-status.jsonl re-ignored 2026-04-30 (cc_p3_209 item 7).
# After the BILLSTATUS-*.zip cosponsor extraction landed, the file
# grew to 346MB (542k edges: 73k sponsors + 468k cosponsors across
# congresses 117-119). Past the GitHub 100MB cap. Local derived data;
# readers go through the relationships-store cross-derived merge,
# bootstrap-worktree-data.cjs mirrors it across worktrees.
data/derived/govinfo-bill-status.jsonl
# Regenerated by scripts/aggregate-pas2-to-edges.cjs after running
# scripts/ingest-fec-pas2-bulk.cjs. Crossed the 50MB large-file-sentinel
# threshold 2026-04-28 PM after the registry-fallback patch landed
# 30k+ new properly-tagged edges. Local derived data; readers go
# through relationships.jsonl which IS canonical.
data/derived/fec-pas2.jsonl
# Regenerated by scripts/aggregate-indiv-to-edges.cjs; churns hard (can reach 1.7GB
# locally during dedup passes before regen). Ops app doesn't import it. Flagship
# readers get data via relationships.jsonl + relationships-per-profile.json.
data/derived/fec-indiv-by-committee.jsonl
# ingest-plaw-bulk.cjs output, 72MB. Ops Ask API loads it at startup on David's
# local machine; not needed in the public Quartz build.
data/bills.jsonl
data/legislator-positions.jsonl
# Per-congress voteview files (595MB total, regeneratable via scripts/ingest-voteview.cjs)
data/legislator-positions/
# Rebuilt in CI by scripts/ci-prebuild.cjs — exceeds GitHub 100MB cap.
# As of ADR-0024 Phase 3 cutover (2026-04-25), built by
# scripts/build-relationships-per-profile.cjs via the librarian.
data/relationships-per-profile.json
quartz/static/profile-index.json

# Unified audit harness artifact (ADR-0021 Phase 1) — regenerated on demand,
# not a source of truth. Future sessions run `node scripts/vault-audit.cjs`
# to refresh.
content/Admin Notes/vault-audit-latest.json

# Dedup script backups — transient snapshots written by dedup-donor-name-variants
# and related scripts. Can be 1.7GB+ (FEC individual data). Not reproducible
# cheaply but not tracked either — they're throwaway safety copies.
data/derived/*.bak
data/derived/*.bak-*
data/derived/*.dedupd-state
data/*.bak
data/*.bak-*
data/*.dedupd-state

# Local backup script log — written by scripts/backup/backup.* scripts;
# noisy and machine-local, not source of truth.
scripts/backup/backup.log

# ADR-0024 cache-correctness: canonical-store mutation stamp. Bumped on every
# write. Read by long-running consumers (ops librarian singleton, /api/connections
# cache) to drop stale snapshots. Machine-local; never commit.
data/.last-mutation
data/_unresolved-edges-summary.json
