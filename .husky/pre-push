#!/usr/bin/env sh
# Pre-push TypeScript gate for the Donor Map vault.
#
# Runs tsc --noEmit on the Quartz build. BLOCKS the push if any TS
# error is reported. The root tsconfig.json excludes ops/ (ops has
# its own tsconfig + is validated separately by the ops-build CI
# job), so this check only covers quartz/.
#
# History: before 2026-04-15 (Pillar 4) this was warn-only because
# quartz/ had 27 pre-existing TS errors (unused vars, D3 type
# mismatches). All 27 were fixed in Pillar 4, so the baseline is
# clean and we flipped this to a hard gate. Any future TS regression
# now blocks the push — fix the error, don't bypass.
#
# Emergency bypass: SKIP_HOOKS=1 git push ...
# (Only use if you're absolutely certain the gate is wrong. Document
# why in your commit message or in content/Admin Notes/bug-queue.md.)

if [ "$SKIP_HOOKS" = "1" ]; then
  echo "[hooks] SKIP_HOOKS=1 — bypassing pre-push check"
  exit 0
fi

echo "--- pre-push gate ---"

# Diagnostic log — captures evidence when a gate flakes. Path is per-run.
# Investigation handoff 2026-04-27: past flakes (3× SKIP_HOOKS=1 in main repo)
# were unreproducible by 2026-04-27. Leading hypothesis: tsc OOM crash when
# NODE_OPTIONS doesn't propagate from interactive shell to git's hook env.
# Next time a gate fires, this log captures full tsc output + node version +
# NODE_OPTIONS so we can confirm or rule out the hypothesis.
PREPUSH_DEBUG_DIR="${TMPDIR:-/tmp}"
PREPUSH_DEBUG_LOG="$PREPUSH_DEBUG_DIR/pre-push-debug-$(date +%Y%m%d-%H%M%S).log"
prepush_dump_env() {
  {
    echo "=== pre-push debug dump ==="
    echo "timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
    echo "pwd: $(pwd)"
    echo "node: $(node --version 2>&1)"
    echo "npx: $(npx --version 2>&1)"
    echo "NODE_OPTIONS: ${NODE_OPTIONS:-<unset>}"
    echo "PATH: $PATH"
    echo "git branch: $(git rev-parse --abbrev-ref HEAD 2>&1)"
    echo "git commit: $(git rev-parse HEAD 2>&1)"
    echo "=== end env dump ==="
  } >> "$PREPUSH_DEBUG_LOG"
}

echo "  -> tsc --noEmit (quartz only, ops excluded)"
# Raise Node heap so tsc doesn't OOM when it resolves the 128MB
# data/relationships-per-profile.json import (rebuilt by ci-prebuild
# and imported by quartz/components/ProfileWidget.tsx + DiscoveryPanel.tsx).
# Default ~2GB heap crashes with "Ineffective mark-compacts near heap limit".
# 8GB gives comfortable headroom on dev machines; CI matches.
export NODE_OPTIONS="${NODE_OPTIONS:---max-old-space-size=8192}"
TS_OUTPUT=$(npx tsc --noEmit 2>&1)
TS_EXIT=$?
if [ $TS_EXIT -ne 0 ]; then
  prepush_dump_env
  {
    echo "=== quartz tsc failed (exit $TS_EXIT) ==="
    echo "$TS_OUTPUT"
    echo "=== end quartz tsc output ==="
  } >> "$PREPUSH_DEBUG_LOG"
  echo ""
  echo "[x] pre-push blocked: TypeScript errors in quartz/"
  echo ""
  echo "$TS_OUTPUT" | tail -30
  echo ""
  # OOM detection — if we see the V8 heap-exhaustion signature, surface it
  # explicitly so the user knows it's a memory crash, not a code regression.
  if printf "%s\n" "$TS_OUTPUT" | grep -qiE "(JavaScript heap out of memory|Ineffective mark-compacts|FATAL ERROR.*heap)"; then
    echo "  [!] DETECTED: tsc crashed from out-of-memory, not from a real TS error."
    echo "      This usually means NODE_OPTIONS didn't propagate. Try:"
    echo "        NODE_OPTIONS='--max-old-space-size=12288' git push ..."
  fi
  echo "  Full debug log: $PREPUSH_DEBUG_LOG"
  echo "  Fix the errors above, or set SKIP_HOOKS=1 for an emergency bypass."
  echo "  NOTE: this gate became strict on 2026-04-15 (Pillar 4). The"
  echo "  baseline was 0 errors at that time. Any new error is a regression."
  exit 1
fi
echo "  ✓ 0 TypeScript errors"

# Ops JSX-structure gate — catches unbalanced tags + parse errors in
# ops/src/. Only checks for syntax-class errors (TS1xxx codes) so the
# worktree's missing-node_modules noise (Cannot find namespace 'React'
# etc.) doesn't generate false positives. The ops-build CI job in main
# repo runs the full ops tsc and catches semantic errors there.
#
# Both tsc and grep can return non-zero in normal flow (tsc when there
# are any errors; grep when no match). We tolerate both via `set +e` +
# explicit exit-code capture so the gate fails ONLY when STRUCTURAL
# errors are actually present.
echo "  -> ops JSX structure (TS1xxx codes only)"
set +e
OPS_TS_OUTPUT=$(npx tsc --project ops/tsconfig.json --noEmit 2>&1)
OPS_STRUCTURAL=$(printf "%s\n" "$OPS_TS_OUTPUT" | grep -E "error TS1[0-9]{3}([^0-9]|$)")
GREP_EXIT=$?
set -e
if [ -n "$OPS_STRUCTURAL" ] && [ "$GREP_EXIT" = "0" ]; then
  prepush_dump_env
  {
    echo "=== ops JSX gate fired ==="
    echo "matched lines (what triggered the block):"
    printf "%s\n" "$OPS_STRUCTURAL"
    echo ""
    echo "full tsc output:"
    printf "%s\n" "$OPS_TS_OUTPUT"
    echo "=== end ops tsc output ==="
  } >> "$PREPUSH_DEBUG_LOG"
  echo ""
  echo "[x] pre-push blocked: structural JSX errors in ops/"
  echo ""
  printf "%s\n" "$OPS_STRUCTURAL" | head -20
  echo ""
  if printf "%s\n" "$OPS_TS_OUTPUT" | grep -qiE "(JavaScript heap out of memory|Ineffective mark-compacts|FATAL ERROR.*heap)"; then
    echo "  [!] DETECTED: ops tsc crashed from out-of-memory, not from a real JSX error."
    echo "      This usually means NODE_OPTIONS didn't propagate. Try:"
    echo "        NODE_OPTIONS='--max-old-space-size=12288' git push ..."
  fi
  echo "  Full debug log: $PREPUSH_DEBUG_LOG"
  echo "  These are unbalanced tags / parse errors. Fix before pushing."
  echo "  Emergency bypass: SKIP_HOOKS=1 git push ..."
  exit 1
fi
echo "  ✓ ops JSX structure clean"

# Publication-readiness gate — enforces CLAUDE.md Rule 10: architecturally
# complete ≠ publication ready. Any profile referenced in data/public-routes.json
# must pass all 8 publication gates (ADR-0017) before deploy. Protects against
# promoting profiles that have (URL NEEDED), broken sources, unapproved class
# tags, etc. Promoted from aspirational to enforced per ADR-0021 Phase 2.
echo "  -> publication-readiness (public-routes only)"
PUB_OUTPUT=$(node scripts/publication-readiness-check.cjs --public-only 2>&1)
PUB_EXIT=$?
if [ $PUB_EXIT -ne 0 ]; then
  echo ""
  echo "[x] pre-push blocked: publication-readiness failed for one or more"
  echo "    profiles in data/public-routes.json"
  echo ""
  echo "$PUB_OUTPUT" | tail -30
  echo ""
  echo "  Fix: either remove the failing route from data/public-routes.json,"
  echo "  or fix the profile to pass the gate. See"
  echo "  content/Checklists/pre-publication.md for the full gate criteria."
  echo ""
  echo "  Emergency bypass: SKIP_HOOKS=1 git push ..."
  exit 1
fi
ROUTES_CHECKED=$(echo "$PUB_OUTPUT" | grep -E "profiles to check" | grep -oE "[0-9]+" | head -1)
echo "  ✓ ${ROUTES_CHECKED:-0} public route(s) pass publication gate"

exit 0
