#!/usr/bin/env sh
# Pre-commit gate for the Donor Map vault.
#
# Runs nine fast sentinels before every commit:
#   1. self-review-mirror      — em dashes, banned AI vocab, defamation-prone words,
#                                verified-profile regressions
#   2. yaml-sanity-scan        — catches broken frontmatter before it lands
#   3. duplicate-bioguide      — catches politician ID collisions
#   4. relationship-edge       — validates data/relationships.jsonl if staged
#                                (Phase 3 canonical edge store)
#   5. canonical-store         — blocks hand-edits to frontmatter relationship
#                                fields unless data/relationships.jsonl or a
#                                rebuilder script is also touched (Phase 3 rule)
#   6. regression-tests        — runs the Phase 6 node:test suite (20 tests,
#                                ~75ms) covering every bug fixed in Phases 1-5
#   7. query-engine-contract   — runs the query-engine API contract tests
#                                (20 tests, ~250ms) locking in the 6-subject
#                                API shape and filter behavior
#   8. deps-staging             — if package.json is staged, require
#                                package-lock.json to be staged too (prevents
#                                the 2026-04-15 Clerk incident class:
#                                deps edited without running npm install)
#   9. auth-smoke              — runs the auth architecture smoke tests
#                                (21 tests, ~70ms) locking in ADR-0009:
#                                OPS_AUTH_BYPASS guards, tier hierarchy,
#                                recovery docs, users.jsonl integrity
#
# If any fail, the commit is blocked. To bypass in an emergency:
#   SKIP_HOOKS=1 git commit ...
# (Do not make this a habit — the hooks exist to protect the vault.)

if [ "$SKIP_HOOKS" = "1" ]; then
  echo "[hooks] SKIP_HOOKS=1 — bypassing pre-commit gate"
  exit 0
fi

echo "--- pre-commit gate ---"

# 1. Self-review mirror (voice + defamation + regression)
echo "  -> self-review-mirror"
node scripts/self-review-mirror.cjs
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] self-review-mirror blocked the commit."
  echo "    Fix the issues above, or set ALLOW_REGRESSION=1 for intentional demotions."
  exit 1
fi

# 2. YAML sanity (broken frontmatter)
echo "  -> yaml-sanity-scan"
node scripts/yaml-sanity-scan.cjs
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] yaml-sanity-scan found broken frontmatter."
  exit 1
fi

# 3. Duplicate bioguide sentinel (politician ID collisions)
echo "  -> duplicate-bioguide-sentinel"
node scripts/duplicate-bioguide-sentinel.cjs
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] duplicate-bioguide-sentinel found ID collisions."
  exit 1
fi

# 4. Relationship edge sentinel (Phase 3 canonical store)
echo "  -> relationship-edge-sentinel"
node scripts/relationship-edge-sentinel.cjs
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] relationship-edge-sentinel rejected the staged JSONL."
  exit 1
fi

# 5. Canonical-store sentinel (Phase 3 write path enforcement)
echo "  -> canonical-store-sentinel"
node scripts/canonical-store-sentinel.cjs
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] canonical-store-sentinel blocked the commit."
  exit 1
fi

# 5b. Profile template validator — 9-section contract for verified profiles
# Per content/Profile Template.md. Only enforces on profiles at
# content-readiness: verified. Lower tiers are skipped.
echo "  -> profile-template-validator"
node scripts/profile-template-validator.cjs --staged
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] profile-template-validator blocked the commit."
  echo "    A profile at content-readiness: verified failed template check."
  echo "    Either fix the profile (add missing sections, clear roadmap markers,"
  echo "    refresh last-enriched) or demote content-readiness back to ready."
  echo ""
  echo "    Spec: content/Profile Template.md"
  echo "    Emergency bypass: SKIP_HOOKS=1 git commit ..."
  exit 1
fi

# 5c. FEC anomaly sentinel — blocks verified profiles referencing a committee
# in the open anomaly queue (pas2-anomalies.jsonl). ADR-0013 / ADR-0014.
# Soft-fails if no anomaly data exists (fresh worktree).
echo "  -> fec-anomaly-sentinel"
node scripts/fec-anomaly-sentinel.cjs --staged
if [ $? -eq 1 ]; then
  echo ""
  echo "[x] fec-anomaly-sentinel blocked the commit."
  echo "    Resolve the flagged committee(s) before promoting to verified."
  exit 1
fi

# 6. Phase 6 regression tests (20 tests, ~75ms, zero deps)
echo "  -> phase-6-regression-tests"
node --test scripts/phase-6-regression-tests.cjs >/dev/null 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] regression tests failed — run 'node --test scripts/phase-6-regression-tests.cjs' to see details."
  exit 1
fi

# 7. Query engine contract tests (20 tests, locks in 6-subject API)
echo "  -> query-engine-contract-tests"
node --test scripts/query-engine-contract-tests.cjs >/dev/null 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] query engine contract tests failed — run 'node --test scripts/query-engine-contract-tests.cjs' to see details."
  exit 1
fi

# 7b. Canonical totals reconciliation — regression catch for silent-
# truncation bugs. Runs the /ask-style pooling logic on a handful of
# hand-curated subjects (Trump, Harris, Leo, McConnell) and asserts
# totals land inside their expected bounds. Two silent-truncation bugs
# slipped past review earlier today — this gate catches the next one.
echo "  -> canonical-totals-reconciliation"
node scripts/reconcile-canonical-totals.cjs --strict >/dev/null 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] canonical-totals reconciliation failed"
  echo "    Run 'node scripts/reconcile-canonical-totals.cjs --verbose' to see which"
  echo "    subject's pooled total drifted out of bounds. Usually means a query"
  echo "    limit was silently truncating or a vehicle was dropped from the"
  echo "    MANUAL_VEHICLE_MAP between route.ts and reconcile-canonical-totals.cjs."
  exit 1
fi

# 8b. Reconciliation framework (tier 1) — surfaces data-integrity drift.
# SOFT gate: reports findings but does not block (2026-04-20). There's a
# known backlog of ~652 pre-existing tier-1 errors being worked through;
# once the backlog is drained this should flip to STRICT mode so new
# errors are blocked at commit time.
#
# What it catches: absurd-value frontmatter (quintillion bug class),
# self-loop edges, cross-source duplicate edges (fec-indiv overlap),
# empty derived tables, unresolved entity references.
#
# Spec: content/Admin Notes/reconciliation-framework-audit-2026-04-20.md
echo "  -> reconciliation-framework (tier 1, soft)"
RECON_OUT=$(node scripts/verify-all.cjs --tier 1 2>&1 | grep -E "TOTAL:" | head -1)
if [ -n "$RECON_OUT" ]; then
  echo "     $RECON_OUT"
fi
# intentionally non-blocking until backlog is drained

# 9. Auth architecture smoke tests (ADR-0009 contracts — 21 tests, ~70ms)
echo "  -> auth-smoke-tests"
node --test scripts/auth-smoke-tests.cjs >/dev/null 2>&1
if [ $? -ne 0 ]; then
  echo ""
  echo "[x] auth smoke tests failed — run 'node --test scripts/auth-smoke-tests.cjs' to see details."
  echo "    This usually means: OPS_AUTH_BYPASS guard removed, tier hierarchy changed,"
  echo "    recovery docs deleted, or data/users.jsonl admin flag broken."
  exit 1
fi

# 8. Deps staging sentinel — if package.json is staged, package-lock.json
# must also be staged (catches "edited deps without running npm install")
echo "  -> deps-staging-sentinel"
STAGED_PKG=$(git diff --cached --name-only | grep -E "(^|/)package\.json$" || true)
if [ -n "$STAGED_PKG" ]; then
  STAGED_LOCK=$(git diff --cached --name-only | grep -E "(^|/)package-lock\.json$" || true)
  MISSING_LOCKS=""
  for pkg in $STAGED_PKG; do
    pkg_dir=$(dirname "$pkg")
    if [ "$pkg_dir" = "." ]; then
      expected_lock="package-lock.json"
    else
      expected_lock="$pkg_dir/package-lock.json"
    fi
    echo "$STAGED_LOCK" | grep -qF "$expected_lock" || MISSING_LOCKS="$MISSING_LOCKS $expected_lock"
  done
  if [ -n "$MISSING_LOCKS" ]; then
    echo ""
    echo "[x] deps-staging-sentinel blocked the commit"
    echo ""
    echo "    You staged a package.json change without the matching package-lock.json:"
    for lock in $MISSING_LOCKS; do
      echo "      missing: $lock"
    done
    echo ""
    echo "    This usually means you edited package.json but forgot to run"
    echo "    npm install (which regenerates the lockfile + node_modules)."
    echo ""
    echo "    Fix:"
    echo "      1. Run \`npm install\` in the drifted directory"
    echo "      2. \`git add <the package-lock.json>\`"
    echo "      3. Retry the commit"
    echo ""
    echo "    Emergency bypass: SKIP_HOOKS=1 git commit ..."
    exit 1
  fi
fi

echo "--- all gates passed ---"
